{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "build",
            "type": "shell", // Use shell for running gcc
            "command": "/usr/bin/gcc",
            "args": [
                "-fdiagnostics-color=always",
                "-g",
                "${file}", // Compiles the currently open file
                "-o",
                "${workspaceFolder}/proj2/n" // Change output to the specified path
            ],
            "options": {
                "cwd": "${fileDirname}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "Task generated by Debugger."
        }
    ]
}
