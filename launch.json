{
  "version": "0.2.0",
  "configurations": [
      {
          "name": "Launch Program",
          "type": "cppdbg",
          "request": "launch",
          "program": "${workspaceFolder}/proj2/n", // 컴파일 되어 나올 파일의 디렉토리
          "args": ["-w", "words.txt"],
          "stopAtEntry": false,
          "cwd": "${workspaceFolder}/proj2", // C코드가 담긴 현재 디렉토리
          "environment": [],
          "externalConsole": false,
          "MIMode": "gdb",
          "setupCommands": [
              {
                  "description": "Enable pretty-printing for gdb",
                  "text": "-enable-pretty-printing",
                  "ignoreFailures": true
              }
          ],
          "preLaunchTask": "build", // This will invoke the build task before launching
          "miDebuggerPath": "/usr/bin/gdb",
          "logging": {
              "moduleLoad": false,
              "trace": false
          }
      }
  ]
}
